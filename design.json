  "aiInstructions": {
    "summary": "Ao implementar qualquer UI neste projeto, siga rigorosamente este design system. O resultado deve parecer um dashboard SaaS premium dark mode: limpo, arejado, com cards arredondados (#1A1A1A sobre #0D0D0D), texto branco para dados importantes, cinza #8E8E93 para labels, e acentos azuis (#3B82F6) apenas para ações primárias e dados ativos.",
    "doList": [
      "Usar Inter como fonte principal.",
      "Manter border-radius de 16px em todos os cards.",
      "Aplicar bordas de 1px #2D2D2D em cards e inputs.",
      "Usar badges pill com dot colorido para status na tabela.",
      "Implementar sidebar com indicador azul de 2px no item ativo.",
      "Manter espaçamento generoso (24px entre seções, 20px padding interno de cards).",
      "Usar linhas de gráfico suaves (spline) com gradiente de área azul.",
      "Implementar hover sutil (surface.hover / surface.elevated) em rows e cards clicáveis."
    ],
    "dontList": [
      "Não usar fundos brancos ou claros.",
      "Não usar sombras pesadas ou neumorphism.",
      "Não usar border-radius inconsistentes (ex: 4px num card e 20px noutro).",
      "Não saturar a interface com múltiplas cores de acento simultaneamente.",
      "Não usar ícones filled/pesados — preferir outline.",
      "Não compactar tabelas — manter padding vertical de 14px por célula.",
      "Não usar gradientes coloridos em backgrounds de cards — apenas em áreas de gráfico."
    ],
    "tokenUsage": "Referencie tokens por caminho (ex: colors.surface.default, typography.scale.body, components.card.padding) ao gerar CSS, Tailwind config ou styled-components.",
    "cssVariablesExample": {
